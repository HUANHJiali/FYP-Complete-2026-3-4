# FYP 生产环境配置模板
# 复制此文件为 .env.production 并填入真实值

# ========================================
# Django 核���配置（⚠️ 生产环境必改）
# ========================================
# ⚠️ 生产环境必须设置为 False
DEBUG=False

# ⚠️ 生产环境必须使用强随机密钥（生成命令：python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"）
SECRET_KEY=your-super-secret-key-change-this-in-production

# 允许的主机（生产环境域名）
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# ========================================
# 数据库配置
# ========================================
DB_HOST=db
DB_PORT=3306
DB_NAME=db_exam
DB_USER=examuser
DB_PASSWORD=your-super-strong-password-here

# 完整数据库 URL（可选，优先级高于单独配置）
# DATABASE_URL=mysql://examuser:password@db:3306/db_exam

# ========================================
# CORS/CSRF 配置
# ========================================
# CORS 允许的源（生产环境前端域名）
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# CSRF 信任的源（生产环境前端域名）
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ========================================
# 缓存配置
# ========================================
# Redis 配置（生产环境推荐）
USE_REDIS=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password

# ========================================
# AI 配置
# ========================================
ZHIPUAI_API_KEY=your-zhipuai-api-key
ZHIPUAI_MODEL=glm-4-flash
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ========================================
# 其他配置
# ========================================
# 静态文件 URL
STATIC_URL=/static/

# 媒体文件 URL
MEDIA_URL=/media/

# 静态文件收集目录
STATIC_ROOT=/app/static

# 媒体文件存储目录
MEDIA_ROOT=/app/media
